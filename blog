    .blog-hero-title{font-size:32px;font-weight:900;color:#fff;line-height:1.1;margin-bottom:12px;letter-spacing:-0.5px;}
    .blog-hero-sub{font-size:14px;color:rgba(255,255,255,0.6);max-width:320px;margin:0 auto;line-height:1.5;}
    .articles-wrap{max-width:640px;margin:0 auto;padding:32px 20px 60px;}
    .section-label{font-size:11px;font-weight:700;color:var(--muted);letter-spacing:2px;text-transform:uppercase;margin-bottom:20px;}
    .article-card{background:#fff;border-radius:20px;overflow:hidden;margin-bottom:20px;border:1px solid var(--border);transition:transform 0.15s,box-shadow 0.15s;text-decoration:none;display:block;color:inherit;}
    .article-card:hover{transform:translateY(-2px);box-shadow:0 8px 24px rgba(28,25,71,0.10);}
    .article-img-placeholder{width:100%;height:180px;background:linear-gradient(135deg,var(--navy) 0%,#2d2870 100%);display:flex;align-items:center;justify-content:center;font-size:52px;}
    .article-card.featured .article-img-placeholder{height:220px;font-size:64px;}
    .article-body{padding:20px;}
    .article-meta{display:flex;align-items:center;gap:8px;margin-bottom:10px;}
    .article-tag{background:var(--gold);color:var(--navy);font-size:10px;font-weight:800;padding:3px 8px;border-radius:20px;text-transform:uppercase;letter-spacing:0.5px;}
    .article-read-time{font-size:11px;color:var(--muted);font-weight:600;}
    .article-title{font-size:18px;font-weight:900;color:var(--navy);line-height:1.25;margin-bottom:8px;letter-spacing:-0.3px;}
    .article-card.featured .article-title{font-size:22px;}
    .article-excerpt{font-size:13px;color:#555;line-height:1.55;margin-bottom:16px;}
    .article-cta{display:inline-flex;align-items:center;gap:6px;background:var(--navy);color:#fff;font-size:12px;font-weight:700;padding:8px 16px;border-radius:20px;text-decoration:none;}
    .article-cta svg{width:12px;height:12px;stroke:currentColor;fill:none;stroke-width:2.5;}
    .subscribe-strip{background:var(--navy);border-radius:20px;padding:28px 24px;text-align:center;margin-top:12px;}
    .subscribe-strip h3{font-size:18px;font-weight:900;color:#fff;margin-bottom:6px;}
    .subscribe-strip p{font-size:13px;color:rgba(255,255,255,0.6);margin-bottom:16px;line-height:1.5;}
    .subscribe-btn{display:inline-block;background:var(--gold);color:var(--navy);font-size:13px;font-weight:800;padding:12px 24px;border-radius:20px;text-decoration:none;}
    .footer{text-align:center;padding:24px 20px;font-size:11px;color:var(--muted);}
    .footer a{color:var(--navy);font-weight:700;text-decoration:none;}
